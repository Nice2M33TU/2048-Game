{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (Ninja + MinGW)",
            "type": "process",
            "command": "${config:2048Game.cmakePath}",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "Ninja",
                "-DCMAKE_MAKE_PROGRAM=${config:2048Game.ninjaPath}",
                "-DCMAKE_C_COMPILER=${config:2048Game.gccPath}",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build EXE",
            "type": "process",
            "command": "${config:2048Game.cmakePath}",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "2048_game"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: Configure (Ninja + MinGW)",
            "problemMatcher": "$gcc"
        },
        {
            "label": "2048: Build and Run",
            "type": "process",
            "command": "${workspaceFolder}\\build\\bin\\2048_game.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: Build EXE",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "focus": true
            }
        },
        {
            "label": "CMake: Clean",
            "type": "process",
            "command": "${config:2048Game.cmakePath}",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
